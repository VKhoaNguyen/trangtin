<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %> - Trang tin điện tử</title>
</head>

<body class="bg-light">
    <div class="container mb-5">
        <%- include('navbar') %>
        
        <div class="card mt-4 shadow-sm border-0">
            <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center py-3">
                <h5 class="mb-0 fw-bold text-primary"><i class="bi bi-journal-bookmark me-2"></i><%= title %></h5>
                <a href="/baiviet/them" class="btn btn-primary btn-sm px-3">
                    <i class="bi bi-plus-lg me-1"></i> Viết bài mới
                </a>
            </div>
            
            <div class="card-body p-0 table-responsive">
                <% if (baiviet.length === 0) { %>
                    <div class="text-center py-5">
                        <i class="bi bi-file-earmark-x display-1 text-muted mb-3"></i>
                        <h5 class="text-muted">Bạn chưa có bài viết nào!</h5>
                        <p class="text-muted small mb-4">Hãy bắt đầu chia sẻ những câu chuyện tuyệt vời của bạn.</p>
                        <a href="/baiviet/them" class="btn btn-outline-primary px-4">Đăng bài ngay</a>
                    </div>
                <% } else { %>
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th width="5%" class="text-center">#</th>
                                <th width="15%">Chủ đề</th>
                                <th width="45%">Tiêu đề</th>
                                <th width="15%">Ngày đăng</th>
                                <th width="10%" class="text-center">Trạng thái</th>
                                <th width="10%" class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% var stt = 1; %>
                            <% baiviet.forEach(function(bv){ %>
                                <tr>
                                    <td class="text-center text-muted fw-semibold"><%= stt++ %></td>
                                    <td><span class="badge bg-secondary"><%= bv.ChuDe.TenChuDe %></span></td>
                                    <td class="fw-medium text-dark"><%= bv.TieuDe %></td>
                                    <td class="small text-muted">
                                        <%= new Date(bv.NgayDang.toISOString()).toLocaleDateString("vi-VN") %>
                                        <br>
                                        <small><%= new Date(bv.NgayDang.toISOString()).toLocaleTimeString("vi-VN") %></small>
                                    </td>
                                    
                                    <td class="text-center">
                                        <% if(bv.KiemDuyet == 1) { %>
                                            <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1">
                                                <i class="bi bi-check-circle-fill me-1"></i>Đã duyệt
                                            </span>
                                        <% } else { %>
                                            <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle px-2 py-1">
                                                <i class="bi bi-hourglass-split me-1"></i>Chờ duyệt
                                            </span>
                                        <% } %>
                                    </td>
                                    
                                    <td class="text-center">
                                        <% if(bv.KiemDuyet == 1) { %>
                                            <div class="btn-group btn-group-sm" role="group">
                                                <button type="button" class="btn btn-light text-muted" title="Không thể sửa bài đã duyệt" disabled><i class="bi bi-pencil-square"></i></button>
                                                <button type="button" class="btn btn-light text-muted" title="Không thể xóa bài đã duyệt" disabled><i class="bi bi-trash"></i></button>
                                            </div>
                                        <% } else { %>
                                            <div class="btn-group btn-group-sm" role="group">
                                                <a href="/baiviet/sua/<%= bv._id %>" class="btn btn-outline-primary" title="Sửa bài"><i class="bi bi-pencil-square"></i></a>
                                                <a href="/baiviet/xoa/<%= bv._id %>" class="btn btn-outline-danger" title="Xóa bài" onclick="return confirm('Bạn có chắc chắn muốn xóa bài viết: <%= bv.TieuDe %>? Hành động này không thể hoàn tác.');">
                                                    <i class="bi bi-trash"></i>
                                                </a>
                                            </div>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                <% } %>
            </div>
        </div>
        
        <div class="mt-4">
            <%- include('footer') %>
        </div>
    </div>
    
    <%- include('javascript') %>
</body>

</html>