<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="Trang tin điện tử hiện đại nhất vũ trụ." />
    <title><%= title %> - iNews</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    
    <style>
        body { background-color: #f8f9fa; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .navbar-brand { font-weight: 800; letter-spacing: -1px; color: #0d6efd !important; font-size: 1.8rem; }
        .card { border: none; transition: transform 0.2s; border-radius: 12px; overflow: hidden; }
        .card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
        .card-img-top { height: 200px; object-fit: cover; }
        .card-title { font-size: 1.1rem; font-weight: 700; line-height: 1.4; height: 3rem; overflow: hidden; }
        .sidebar-title { border-left: 4px solid #0d6efd; padding-left: 10px; font-weight: 700; margin-bottom: 20px; }
        .footer { background: #212529; color: #888; padding: 40px 0; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
        <div class="container">
            <a class="navbar-brand" href="/">iNews</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle fw-bold" href="#" data-bs-toggle="dropdown">Chuyên mục</a>
                        <ul class="dropdown-menu shadow-sm">
                            <% if(typeof chuyenmuc !== "undefined") { chuyenmuc.forEach(cd => { %>
                                <li><a class="dropdown-item" href="/baiviet/chude/<%= cd._id %>"><%= cd.TenChuDe %></a></li>
                            <% }); } %>
                        </ul>
                    </li>
                </ul>
                <div class="d-flex align-items-center">
                    <form class="me-3" action="/timkiem" method="post">
                        <div class="input-group input-group-sm">
                            <input name="tukhoa" class="form-control" type="text" placeholder="Tìm kiếm...">
                            <button class="btn btn-outline-primary" type="submit"><i class="bi bi-search"></i></button>
                        </div>
                    </form>
                    <% if(typeof session === "undefined" || !session.MaNguoiDung) { %>
                        <a href="/dangnhap" class="btn btn-sm btn-outline-dark me-2">Đăng nhập</a>
                        <a href="/dangky" class="btn btn-sm btn-primary">Đăng ký</a>
                    <% } else { %>
                        <div class="dropdown">
                            <button class="btn btn-sm btn-light dropdown-toggle" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i> <%= session.HoVaTen %>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                                <li><a class="dropdown-item" href="/baiviet/cuatoi">Bài viết của tôi</a></li>
                                <% if(session.QuyenHan == 'admin') { %>
                                    <li><a class="dropdown-item fw-bold text-primary" href="/baiviet">Quản lý bài viết</a></li>
                                <% } %>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="/dangxuat">Đăng xuất</a></li>
                            </ul>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>

    <main class="container mt-4">
        <div class="row">
            <div class="col-lg-9">
                <h4 class="sidebar-title">Tin mới nhất</h4>
                <div class="row g-4">
                    <% if(typeof baiviet !== "undefined" && baiviet.length > 0) { %>
                        <% baiviet.forEach(bv => { %>
                            <div class="col-md-6 col-xl-4">
                                <div class="card h-100 shadow-sm">
                                    <a href="/baiviet/chitiet/<%= bv._id %>">
                                        <img src="<%- firstImage(bv.NoiDung) %>" class="card-img-top" alt="...">
                                    </a>
                                    <div class="card-body">
                                        <div class="mb-2">
                                            <span class="badge bg-primary-subtle text-primary small"><%= bv.ChuDe.TenChuDe %></span>
                                            <small class="text-muted ms-2"><%= new Date(bv.NgayDang).toLocaleDateString("vi-VN") %></small>
                                        </div>
                                        <a href="/baiviet/chitiet/<%= bv._id %>" class="text-decoration-none text-dark">
                                            <h5 class="card-title"><%= bv.TieuDe %></h5>
                                        </a>
                                        <p class="card-text small text-muted text-truncate-3"><%= bv.TomTat %></p>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="col-12 text-center py-5">
                            <p class="text-muted">Chưa có bài viết nào được đăng.</p>
                        </div>
                    <% } %>
                </div>
            </div>

            <div class="col-lg-3 mt-4 mt-lg-0">
                <div class="sticky-top" style="top: 80px;">
                    <div class="card mb-4 bg-primary text-white">
                        <div class="card-body text-center p-4">
                            <h5>Chào mừng bạn!</h5>
                            <p class="small opacity-75 mb-0">iNews là nơi cập nhật những tin tức nóng hổi nhất mỗi ngày.</p>
                        </div>
                    </div>

                    <h5 class="sidebar-title">Chủ đề phổ biến</h5>
                    <div class="d-flex flex-wrap gap-2 mb-4">
                        <% if(typeof chuyenmuc !== "undefined") { chuyenmuc.forEach(cd => { %>
                            <a href="/baiviet/chude/<%= cd._id %>" class="btn btn-sm btn-white shadow-sm border"><%= cd.TenChuDe %></a>
                        <% }); } %>
                    </div>

                    <h5 class="sidebar-title">Xem nhiều nhất</h5>
                    <% if(typeof xemnhieunhat !== "undefined") { xemnhieunhat.forEach(bv => { %>
                        <div class="mb-3">
                            <a href="/baiviet/chitiet/<%= bv._id %>" class="text-decoration-none text-dark d-flex align-items-center">
                                <img src="<%- firstImage(bv.NoiDung) %>" class="rounded me-2" style="width: 60px; height: 60px; object-fit: cover;">
                                <h6 class="small mb-0 fw-bold"><%= bv.TieuDe %></h6>
                            </a>
                        </div>
                    <% }); } %>
                </div>
            </div>
        </div>
    </main>

    <footer class="footer mt-5">
        <div class="container text-center">
            <p class="mb-2">iNews - Trang tin điện tử tương lai</p>
            <div class="small text-muted mb-3">
                <a href="#" class="text-secondary mx-2">Liên hệ</a> | 
                <a href="#" class="text-secondary mx-2">Chính sách</a> | 
                <a href="#" class="text-secondary mx-2">Quảng cáo</a>
            </div>
            <div class="copy text-light opacity-50 small">
                Bản quyền &copy; 2026 bởi Võ Khoa Nguyên.
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>